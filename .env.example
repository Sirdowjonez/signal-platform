# Server
PORT=3001
NODE_ENV=development

# Database
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/signal

# Auth
JWT_SECRET=your-super-secret-jwt-key-change-this

# Stripe ($29/mo membership)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PRICE_ID=price_...
STRIPE_WEBHOOK_SECRET=whsec_...

# OneSignal (push notifications)
ONESIGNAL_APP_ID=your-onesignal-app-id
ONESIGNAL_REST_API_KEY=your-onesignal-rest-key

# News APIs (for ingestion pipeline)
NEWS_API_KEY=your-newsapi-key
OPENAI_API_KEY=sk-...

# Client
REACT_APP_STRIPE_PUBLISHABLE_KEY=pk_test_...
REACT_APP_ONESIGNAL_APP_ID=your-onesignal-app-id
